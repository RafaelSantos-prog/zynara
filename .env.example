# Root shared environment for frontend, backend and voice-assistant

# Frontend
VITE_API_URL=http://localhost:3001
VITE_GOOGLE_CLIENT_ID=SEU_CLIENT_ID

# Backend
DATABASE_URL=file:./dev.db
GOOGLE_CLIENT_ID=SEU_CLIENT_ID
GOOGLE_CLIENT_SECRET=SEU_CLIENT_SECRET
JWT_SECRET=troque-em-producao
GEMINI_API_KEY=SUA_CHAVE_GEMINI
GEMINI_MODEL=gemini-2.5-flash
MP_ACCESS_TOKEN=SEU_TOKEN_MP
PORT=3001
GUEST_MAX_USER_MESSAGES=50
GUEST_SESSION_TTL_MIN=120

# Voice assistant
PIPER_BINARY=/home/SEU_USUARIO/Documentos/zynara/zynara/voice-assistant/.venv/bin/piper
PIPER_MODEL_PATH=/path/to/pt_BR-voice.onnx
AUDIO_PLAYER=aplay
AUDIO_INPUT_DEVICE=
MAX_HISTORY_MESSAGES=24
VOICE_ASSISTANT_HISTORY_PATH=
VOICE_ASSISTANT_PREFS_PATH=
GEMINI_API_KEY=SUA_CHAVE_GEMINI
GEMINI_MODEL=gemini-2.5-flash
VOICE_ASSISTANT_WHISPER_MODEL_SIZE=base
VOICE_ASSISTANT_WHISPER_DEVICE=cpu
VOICE_ASSISTANT_WHISPER_COMPUTE_TYPE=int8
VOICE_ASSISTANT_USE_VAD=true
VOICE_ASSISTANT_SILENCE_THRESHOLD=0.015
VOICE_ASSISTANT_SILENCE_SECONDS=1.0
VOICE_ASSISTANT_MIN_RECORD_SECONDS=0.6
VOICE_ASSISTANT_MAX_RECORD_SECONDS=20.0
VOICE_ASSISTANT_RECORD_SECONDS=
