generator client {
  provider = "prisma-client-js"
}

// Default local development uses SQLite.
// For production MySQL, switch the datasource provider to "mysql" and keep the same model shape.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String              @id @default(cuid())
  googleId          String              @unique
  email             String              @unique
  name              String
  avatarUrl         String?
  passwordHash      String?
  lang              String              @default("pt-BR")
  plan              String              @default("free")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  onboardingAnswers OnboardingAnswer[]
  sessions          Session[]
  subscriptions     Subscription[]

  @@map("users")
}

model OnboardingAnswer {
  id           String   @id @default(cuid())
  userId       String
  questionKey  String
  answer       String
  answeredAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("onboardingAnswers")
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  title       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([userId])
  @@map("sessions")
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  sentAt    DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("messages")
}

model Subscription {
  id                String   @id @default(cuid())
  userId            String
  mpSubscriptionId  String?
  status            String
  planId            String
  startedAt         DateTime @default(now())
  expiresAt         DateTime?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}
